# ============================================================================
# MyVCS .gitignore
# ============================================================================

# ----------------------------------------------------------------------------
# Sensitive Files (NEVER commit these)
# ----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# ----------------------------------------------------------------------------
# Build Outputs
# ----------------------------------------------------------------------------

# C++ Engine
vcs-engine/bin/
vcs-engine/obj/
*.o
*.out
*.exe

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# React Dashboard
web-dashboard/dist/
web-dashboard/build/
.vite/

# ----------------------------------------------------------------------------
# IDE & Editor
# ----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----------------------------------------------------------------------------
# Testing
# ----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# ----------------------------------------------------------------------------
# MyVCS Repository Data (for testing)
# ----------------------------------------------------------------------------
.myvcs/

# ----------------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------------
*.log
logs/

# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------
*.tmp
*.temp
.cache/
