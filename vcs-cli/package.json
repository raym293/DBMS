{
  "name": "myvcs-cli",
  "version": "1.0.0",
  "description": "MyVCS - Custom Version Control System CLI",
  "type": "module",
  "main": "src/main.js",
  "bin": {
    "myvcs": "./src/main.js"
  },
  "scripts": {
    "start": "node src/main.js",
    "dev": "node --watch src/main.js",
